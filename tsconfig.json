{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",           // <== هنا عدلنا
    "moduleResolution": "Node16", // <== يتوافق مع module
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react-jsx",           // JSX يعمل
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src", "artifacts/mockup-sandbox/src"],
  "exclude": ["node_modules", "dist"]
}
